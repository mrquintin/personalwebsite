{
  "ci": {
    "collect": {
      "startServerCommand": "npm run start",
      "startServerReadyPattern": "Ready|started server on|Local:",
      "url": [
        "http://localhost:3000/",
        "http://localhost:3000/projects",
        "http://localhost:3000/projects/hivemind",
        "http://localhost:3000/projects/purposeless-efficiency",
        "http://localhost:3000/projects/theseus",
        "http://localhost:3000/about",
        "http://localhost:3000/resume",
        "http://localhost:3000/chat"
      ],
      "numberOfRuns": 1
    },
    "assert": {
      "assertMatrix": [
        {
          "matchingUrlPattern": "/chat$",
          "assertions": {
            "categories:performance": ["error", { "minScore": 0.80 }],
            "categories:accessibility": ["error", { "minScore": 0.95 }],
            "categories:best-practices": ["error", { "minScore": 0.95 }],
            "categories:seo": ["error", { "minScore": 0.95 }]
          }
        },
        {
          "matchingUrlPattern": "^(?!.*\\/chat$).*$",
          "assertions": {
            "categories:performance": ["error", { "minScore": 0.90 }],
            "categories:accessibility": ["error", { "minScore": 0.95 }],
            "categories:best-practices": ["error", { "minScore": 0.95 }],
            "categories:seo": ["error", { "minScore": 0.95 }]
          }
        }
      ]
    }
  }
}

exports[`Prose > nests Anchor and Aside without throwing and preserves structure 1`] = `"<p>intro</p><h2 id="approach" class="p-anchor"><span aria-hidden="true" class="p-anchor__sigil">§</span><span class="p-anchor__label">Approach</span><button type="button" aria-label="Copy link to Approach" class="p-anchor__copy">#</button></h2><p>body</p><section class="p-surface p-surface--mute p-surface--bordered p-aside p-aside--note" style="padding: var(--s-5);" role="note"><div class="p-aside__label" data-tone="note">NOTE</div><div class="p-aside__body">side note</div></section><p>outro</p>"`;
